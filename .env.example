# ============================================================
# LLM Trading System — Environment Variables
# Kopyala: copy .env.example .env  → kendi anahtarlarınızı girin
# ============================================================

# ── LLM Providers ──────────────────────────────────────────
# OpenRouter (Birincil) — https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxx
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_DEFAULT_MODEL=deepseek/deepseek-chat-v3-0324
OPENROUTER_REASONING_MODEL=deepseek/deepseek-reasoner

# DeepSeek (Doğrudan API) — https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Ollama (Yerel) — varsayılan localhost:11434
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3:8b

# ── Exchange ───────────────────────────────────────────────
# Binance — https://www.binance.com/en/my/settings/api-management
BINANCE_API_KEY=xxxxxxxxxxxxxxxxxxxxx
BINANCE_API_SECRET=xxxxxxxxxxxxxxxxxxxxx
BINANCE_TESTNET=true

# Multi-Account Support (JSON format)
# Örnek: [{"name": "Main", "api_key": "...", "api_secret": "..."}, {"name": "Secondary", "api_key": "...", "api_secret": "..."}]
# Not: BINANCE_ACCOUNTS_JSON varsa, BINANCE_API_KEY/SECRET yerine kullanılır
# JSON tek satırda veya \n ile alt satıra geçebilir
BINANCE_ACCOUNTS_JSON=[{"name": "Main", "api_key": "your_main_api_key", "api_secret": "your_main_api_secret"}]

# ── News & Data ────────────────────────────────────────────
# Finnhub (Ücretsiz plan: 60 istek/dk) — https://finnhub.io/register
FINNHUB_API_KEY=xxxxxxxxxxxxxxxxxxxxx

# ── Ensemble LLM ───────────────────────────────────────────
ENSEMBLE_ENABLED=true
ENSEMBLE_MODELS=deepseek/deepseek-chat-v3-0324,ollama/llama3:8b
ENSEMBLE_MIN_CONSENSUS=0.6

# ── Notifications ──────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ── System ─────────────────────────────────────────────────
LOG_LEVEL=INFO
TRADING_MODE=paper
